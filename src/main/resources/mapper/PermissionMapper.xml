<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="io.github.kkngai.estorecheckout.mapper.PermissionMapper">

    <resultMap id="permissionResultMap" type="io.github.kkngai.estorecheckout.model.Permission">
        <id property="permissionId" column="permission_id"/>
        <result property="permissionName" column="permission_name"/>
    </resultMap>

    <select id="findById" resultMap="permissionResultMap">
        SELECT permission_id, permission_name
        FROM permissions
        WHERE permission_id = #{permissionId}
    </select>

    <select id="findByPermissionName" resultMap="permissionResultMap">
        SELECT permission_id, permission_name
        FROM permissions
        WHERE permission_name = #{permissionName}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="permissionId">
        INSERT INTO permissions (permission_name)
        VALUES (#{permissionName})
    </insert>

    <update id="update">
        UPDATE permissions
        SET permission_name = #{permissionName}
        WHERE permission_id = #{permissionId}
    </update>

    <delete id="deleteById">
        DELETE FROM permissions
        WHERE permission_id = #{permissionId}
    </delete>

</mapper>